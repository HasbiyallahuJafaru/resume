# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Paystack
PAYSTACK_SECRET_KEY="sk_live_YOUR_SECRET_KEY_HERE"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_live_YOUR_PUBLIC_KEY_HERE"

# Payment amount in kobo (NGN) - 500000 = ₦5,000
NEXT_PUBLIC_PAYMENT_AMOUNT=500000
NEXT_PUBLIC_PAYMENT_CURRENCY="NGN"

# App
NEXT_PUBLIC_APP_URL="https://atsresume.xyz"
NEXT_PUBLIC_APP_NAME="ResumeForge"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# Pollinations AI
POLLINATIONS_AI_URL="https://text.pollinations.ai"
